{
  "name": "meal-planner",
  "version": "1.0.0",
  "scripts": {
    "apply-infra": "yarn workspace @meal-planner/infrastructure deploy",
    "deploy-backend": "make -C packages/api package && yarn apply-infra",
    "build-frontend": "yarn workspace @meal-planner/infrastructure output && yarn workspace @meal-planner/web-client-v2 build",
    "deploy-frontend": "yarn build-frontend && yarn workspace @meal-planner/infrastructure invalidate-frontend",
    "frontend-dev": "yarn workspace @meal-planner/web-client-v2 dev"
  },
  "private": true,
  "workspaces": [
    "packages/api",
    "packages/cli",
    "packages/infrastructure",
    "packages/web-client-v2"
  ],
  "devDependencies": {}
}
