{
  "name": "meal-planner",
  "version": "1.0.0",
  "scripts": {
    "infra:apply": "terraform -chdir=packages/infrastructure apply -auto-approve",
    "infra:output": "terraform -chdir=packages/infrastructure output -json > packages/web-client-v2/output.json",
    "backend:build": "make -C packages/functions build",
    "backend:deploy": "make -C packages/functions package && yarn infra:apply",
    "frontend:build": "yarn infra:output && yarn --cwd packages/web-client-v2 build",
    "frontend:sync": "aws s3 sync packages/web-client-v2/dist s3://$(terraform -chdir=packages/infrastructure output -raw webclient_bucket) --delete",
    "frontend:invalidate": "aws cloudfront create-invalidation --path '/*' --distribution-id $(terraform -chdir=packages/infrastructure output -raw cloudfront_distribution_id)",
    "frontend:deploy": "yarn frontend:build && yarn frontend:sync && yarn frontend:invalidate",
    "frontend:serve": "yarn --cwd packages/web-client-v2 dev"
  },
  "private": true
}
