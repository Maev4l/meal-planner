{
  "name": "@meal-planner/infrastructure",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "output": "terraform output -json | jq '{mealPlannerUserPoolId: .cognito_user_pool_id.value, mealPlannerClientId: .cognito_user_pool_client_id.value, mealPlannerRegion: .region.value}' > ../web-client-v2/output.json",
    "deploy": "terraform apply -auto-approve && yarn output",
    "invalidate-frontend": "aws cloudfront create-invalidation --path '/*' --distribution-id $(terraform output -raw cloudfront_distribution_id)"
  }
}
